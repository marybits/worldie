# ── Server ──────────────────────────────────
PORT=8080
NODE_ENV=production

# ── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/worldie

# ── Auth ─────────────────────────────────────
# Must be a long random string (min 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend-url.com/api/auth/google/callback

# ── Client URL (for CORS + OAuth redirect) ───
CLIENT_URL=https://your-frontend-url.com

# ── Football Data API ─────────────────────────
# Get your key at https://www.football-data.org/
FOOTBALL_API_KEY=your_football_data_api_key

# ── Admin ─────────────────────────────────────
# Used to protect /api/matches/sync and /api/matches/:id/calculate
# Generate with: openssl rand -hex 24
ADMIN_SECRET=your_admin_secret_here
